{
  "manifest_version": 3,
  "name": "Digital Store – CRM for WhatsApp",
  "version": "1.1.0",
  "description": "Powerful CRM assistant for WhatsApp Web. Manage customers, sales, expenses, and invoices directly from your chat.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://digital-store.top/*",
    "http://localhost/*",
    "http://localhost:8000/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
